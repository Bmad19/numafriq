# Copier vers .env.production puis adapter les URLs (sans slash final).
# Utilisé automatiquement par : npm run build
#
# URL de l’API Node déployée (Render, Railway, VPS…) — même origine pour les 4 lignes :

VITE_BUREAU_API=https://VOTRE-API.example.com/api/bureau
VITE_CLIENT_API=https://VOTRE-API.example.com/api/client
VITE_CHAT_API_URL=https://VOTRE-API.example.com/api/chat.php
VITE_API_URL=https://VOTRE-API.example.com/api/contact.php

# Optionnel — si différent de (origine de VITE_API_URL)/api/careers.php
# VITE_CAREERS_API_URL=https://VOTRE-API.example.com/api/careers.php

# Optionnel — articles / blog WordPress (REST) pour Afrilex Conseil
# VITE_WP_REST_BASE=https://afrilexconseil.com/wp-json
