# Copier vers .env.production une fois ; puis uniquement « npm run build » et envoyer dist/ sur l’hébergeur.
#
# Site à la racine du domaine (ex. public_html de afrilexconseil.com) : OBLIGATOIRE pour les routes SPA
# (/recrutement, /blog/..., etc.) — sinon les scripts se chargent depuis /recrutement/assets/… (404).
VITE_BASE_PATH=/
#
# Déploiement uniquement dans un sous-dossier FTP (ex. /afrilex/) : commentez la ligne ci-dessus et utilisez :
# VITE_BASE_PATH=/afrilex/

VITE_BUREAU_API=https://VOTRE-SERVICE.onrender.com/api/bureau
VITE_CLIENT_API=https://VOTRE-SERVICE.onrender.com/api/client
VITE_CHAT_API_URL=https://VOTRE-SERVICE.onrender.com/api/chat.php
VITE_API_URL=https://VOTRE-SERVICE.onrender.com/api/contact.php

# Formulaire carrières (optionnel — par défaut le front utilise /api/careers.php sur la même origine que le site)
# VITE_CAREERS_API_URL=https://VOTRE-SERVICE.onrender.com/api/careers.php

# Blog WordPress (optionnel — défaut afrilexconseil.com/wp-json si vide au build)
# VITE_WP_REST_BASE=https://votredomaine.com/wp-json