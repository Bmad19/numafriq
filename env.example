# ══════════════════════════════════════════════════════════════════════════════
# Développement — copier vers .env.local à la racine du dossier afrilex
# ══════════════════════════════════════════════════════════════════════════════

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Chat site + assistant bureau (Groq) — uniquement côté serveur API
GROQ_API_KEY=

# CORS : en local, localhost est en général accepté (voir scripts/bureau-api.cjs).

# Réinit. mot de passe compte secours « afrilex_agent » (hash embarqué) au prochain démarrage :
# AFRILEX_SYNC_AGENT_LOGIN=1

# Réaligner « sagnon » sur le mot de passe bootstrap SAGNON (hash dans bureau-api.cjs) — une fois après mise à jour API, puis retirer :
# AFRILEX_LOCAL_SYNC_SAGNON=1

# WhatsApp (optionnel)
# WA_PHONE=
# META_ACCESS_TOKEN=
# META_PHONE_ID=

# Origines prod supplémentaires (virgules)
# CORS_ORIGINS=https://www.afrilexconseil.com,https://afrilexconseil.com

# Optionnel — regex séparées par virgules si le domaine ne finit pas par afrilexconseil.com / numafriq.com
# CORS_ORIGIN_PATTERNS=^https://mon-site\.fr$,^https://www\.mon-site\.fr$

# ══════════════════════════════════════════════════════════════════════════════
# Production — tableaux Environment sur Render / Railway (secrets)
# ══════════════════════════════════════════════════════════════════════════════
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# GROQ_API_KEY=
# CORS_ORIGINS=
# PORT est défini automatiquement sur la plupart des PaaS

# ══════════════════════════════════════════════════════════════════════════════
# Production — build frontend : fichier .env.production (voir .env.production.example)
# ══════════════════════════════════════════════════════════════════════════════
# VITE_BUREAU_API=https://votre-api.onrender.com/api/bureau
# VITE_CLIENT_API=https://votre-api.onrender.com/api/client
# VITE_CHAT_API_URL=https://votre-api.onrender.com/api/chat.php
# VITE_API_URL=https://votre-api.onrender.com/api/contact.php
# VITE_CAREERS_API_URL=https://votre-api.onrender.com/api/careers.php
# VITE_WP_REST_BASE=https://votredomaine.com/wp-json

# Dev uniquement : « 1 » = blog lit WordPress en direct (ignore blog-feed.json)
# VITE_BLOG_USE_LIVE_WP=1
