# ── NUMAFRIQ — Redirection SPA React Router ──────────────────────────────────
Options -MultiViews
RewriteEngine On

# HTTPS forcé
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Rediriger www → sans www (optionnel, adapter selon votre config LWS)
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Ne pas réécrire si le fichier ou dossier existe réellement
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Tout le reste → index.html (React Router gère la navigation)
RewriteRule ^ /index.html [QSA,L]

# ── Cache long terme pour les assets hashés (JS/CSS/images) ──────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html             "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css              "access plus 1 year"
  ExpiresByType image/png             "access plus 1 year"
  ExpiresByType image/jpeg            "access plus 1 year"
  ExpiresByType image/webp            "access plus 1 year"
  ExpiresByType image/svg+xml        "access plus 1 year"
  ExpiresByType font/woff2            "access plus 1 year"
</IfModule>

# ── Compression Gzip ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
