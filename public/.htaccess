# ── Afrilex Conseil — SPA React Router (Apache / public_html / LWS-type) ─────
# Important : ce fichier doit être à la racine du site avec index.html.

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Laisser passer fichiers et dossiers réels (assets/, favicon, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # WordPress REST : si WP est installé dans un sous-dossier (ex. /wordpress),
  # décommentez et adaptez le chemin — sinon /wp-json est mangé par la SPA.
  # RewriteRule ^wp-json(/.*)?$ /wordpress/wp-json$1 [L,QSA]

  # Sinon → SPA (chemins relatifs ou absolus selon le build)
  RewriteRule . index.html [L]
</IfModule>

<IfModule mod_mime.c>
  AddType application/javascript js mjs
  AddType text/css css
</IfModule>

# ── Cache long terme pour les assets hashés ───────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html              "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css               "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
</IfModule>

# ── Compression Gzip ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
